# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/eventmanagement?retryWrites=true&w=majority&appName=Cluster0

# Google Gemini API key — copy full key from https://aistudio.google.com/apikey
# Keys may start with AIza... or AQ.
GEMINI_API_KEY=your_gemini_api_key_here
